{
  "name": "hoba-webapp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hoba! Telegram Mini App — React + Vite + TS",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
