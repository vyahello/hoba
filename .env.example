# Hoba! environment — copy to .env and fill in.
# Do NOT commit .env. See .gitignore.

# Telegram bot — get from @BotFather for @hobagame_bot.
# Leave empty in dev to start the bot service in disabled (idle) mode.
TELEGRAM_BOT_TOKEN=

# Bot username (no leading @). Used for deep links and inline mode.
TELEGRAM_BOT_USERNAME=hobagame_bot

# Webapp-side env (Vite, embedded at build time). Defaults match the
# server-side TELEGRAM_BOT_USERNAME above and an unset short_name.
# Set VITE_TELEGRAM_APP_SHORT_NAME to your BotFather `/newapp` short name
# to switch share links to Direct Link Mini App form
# (`t.me/<bot>/<short>?startapp=…`), which auto-launches the Mini App
# with start_param on modern clients. Leave empty for menu-button form.
VITE_TELEGRAM_BOT_USERNAME=hobagame_bot
VITE_TELEGRAM_APP_SHORT_NAME=

# Comma-separated extra hostnames Vite's dev server should accept on
# the Host header. Required when serving behind a reverse proxy on a
# hostname Vite doesn't auto-allow. `*.duckdns.org`, `*.ngrok.io`,
# `*.trycloudflare.com`, etc. are already covered in vite.config.ts.
# Soft-launch on a custom domain → list it here.
# Example: VITE_ALLOWED_HOSTS=hoba.example.com,play.example.com
VITE_ALLOWED_HOSTS=

# SQLAlchemy URL. Default: SQLite file in ./data (mounted into containers).
# Swap to e.g. postgresql+asyncpg://user:pw@host:5432/hoba for production.
DATABASE_URL=sqlite+aiosqlite:///./data/hoba.db

# Redis 7 — ephemeral game state, presence, rate limits.
# Inside docker compose the hostname is the service name `redis`.
REDIS_URL=redis://redis:6379/0

# Public HTTPS URL the Mini App is served from (the URL Telegram opens).
# In dev: run `ngrok http 5173` and paste the returned https://*.ngrok-free.app
# URL here, then restart the bot service.
# In prod: same value as DOMAIN below, e.g. https://hoba.example.com
WEBAPP_URL=https://your.tunnel.url

# Production-only — bare hostname Caddy serves on (no scheme, no path).
# DNS A-record for this name must point to the VPS public IP. Caddy
# requests a Let's Encrypt cert for this name on first boot (ports
# 80 + 443 must be open). Ignored by the dev profile.
DOMAIN=

# Signing key for internal tokens / signed payloads.
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# Sentry DSN — optional in dev, required in prod.
SENTRY_DSN=

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Run `alembic upgrade head` on API startup. Default true — set false in
# environments where migrations run as a separate deployment step.
AUTO_MIGRATE=true

# Room-creation rate limit: max room creations per user per window.
# Default 5 / 3600s (1 hour) for prod abuse protection. Raise the max for
# heavy manual testing (e.g. 1000), then restart the api container.
ROOM_CREATE_RATE_LIMIT_MAX=5
ROOM_CREATE_RATE_LIMIT_WINDOW_SECONDS=3600
